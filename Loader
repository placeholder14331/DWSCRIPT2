if IdkWhatToPutInThisButIGuessThatsItAndOhBtwJoinAWP[placeId] then
    repeat task.wait() until game:IsLoaded()
    if isXeno or isSolara or isLuna then
        notify("Serenium", "Solara/Xeno Detected, loading supported version")
