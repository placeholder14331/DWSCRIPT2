    [72144869714561]  = true, -- DW LC MGSVR
    [112060227074307] = true, -- DW LC NGTY
    [115209351507608] = true, -- The Armory
}

local awp = {
    [18259975825]     = true, -- G/N
    [114931763326993] = true, -- DW LEGACY
    [109185433585492] = true, -- DW LEGACY NGTMR
    [155615604]       = true, -- Prison life
    [135564683255158] = true, -- Prison life VC
